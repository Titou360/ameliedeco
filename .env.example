# URL publique du site (utilisée par metadataBase, sitemap, canonical, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://www.ameliedeco.com

# MongoDB Atlas — renseigner dans .env.local (JAMAIS committer la vraie valeur).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?appName=AmelieDeco
MONGODB_DB=ameliedeco

# Auth.js (secret fort : openssl rand -base64 32)
AUTH_SECRET=
# Brevo (email transactionnel) — expéditeur = adresse vérifiée dans Brevo
BREVO_API_KEY=
BREVO_SENDER=
# Mots de passe initiaux des comptes admin (script de seed, à usage unique)
SEED_AMELIE_PASSWORD=
SEED_CLEMENT_PASSWORD=
